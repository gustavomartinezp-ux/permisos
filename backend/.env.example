# =============================================================
#  Copia este archivo como .env y completa los valores
#  (también puedes partir del template.env en la raíz del proyecto)
# =============================================================

PORT=3001
NODE_ENV=development

# ── Base de datos ──────────────────────────────────────────────
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DB

DB_HOST=localhost
DB_PORT=5432
DB_NAME=cesfam_permisos
DB_USER=cesfam_admin
DB_PASSWORD=

# ── Autenticación JWT ──────────────────────────────────────────
JWT_SECRET=
JWT_EXPIRES_IN=8h

# ── CORS ───────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173

# ── Usuarios nuevos ────────────────────────────────────────────
# Contraseña inicial que se asigna al crear un funcionario con cuenta
INITIAL_PASSWORD=
