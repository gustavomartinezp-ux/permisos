# =============================================================
#  CESFAM Los Cerros — Plantilla de variables de entorno
#  Copia este archivo como  backend\.env  y completa los valores
# =============================================================

PORT=3001
NODE_ENV=development

# ── Base de datos ──────────────────────────────────────────────
# Supabase: Supabase > Project Settings > Database > Connection string > URI
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DB

# Base de datos local con Docker (solo si usas docker-compose)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=cesfam_permisos
DB_USER=cesfam_admin
DB_PASSWORD=

# ── Autenticación JWT ──────────────────────────────────────────
# Genera una clave aleatoria larga (min. 32 caracteres)
JWT_SECRET=
JWT_EXPIRES_IN=8h

# ── CORS ───────────────────────────────────────────────────────
# Desarrollo: http://localhost:5173
# Producción: URL de Firebase Hosting (deploy.bat la asigna automáticamente)
FRONTEND_URL=http://localhost:5173
